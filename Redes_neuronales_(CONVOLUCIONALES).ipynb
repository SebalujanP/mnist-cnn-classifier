      "source": [
        "test_loss,test_accuracy=model.evaluate(\n",
        "    x_test,\n",
        "    y_test\n",
        ")\n",
        "\n",
        "print(\"Resultado del accury:  \",test_accuracy)"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "jPFxUePGpCHJ"
      },
      "source": [
        "Probamos el modelo nosotros"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 806
        },
        "collapsed": true,
        "id": "PZ3W1r9mxcDB",
        "outputId": "29ec8c07-d674-4b4e-e6ed-7a1fbc0ac40c"
      },
      "outputs": [
        {
          "data": {
            "image/png": "\n",
            "text/plain": [
              "<Figure size 800x800 with 25 Axes>"
            ]
          },
          "metadata": {},
          "output_type": "display_data"
        }
      ],
      "source": [
        "imagenes, etiquetas = next(iter(train_dataset))\n",
        "\n",
        "plt.figure(figsize=(8,8))\n",
        "\n",
        "for i in range(25):\n",
        "    plt.subplot(5,5,i+1)\n",
        "    plt.imshow(imagenes[i].numpy().squeeze(), cmap=\"gray\")\n",
        "    plt.title(str(etiquetas[i].numpy()))\n",
        "    plt.axis(\"off\")\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "qH5qXlt_9GE9"
      },
      "outputs": [],
      "source": [
        "def predecir(imagen):\n",
        "    if imagen is None:\n",
        "        return {}\n",
        "\n",
        "    
        "   
        "    capa = imagen[\"layers\"][0]       
        "    alpha = capa[:, :, 3]            
        "\n",
        "    # Redimensionar a 28x28\n",
        "    imagen_28 = cv2.resize(alpha, (28, 28))\n",
        "\n",
        "    # Normalizar (el trazo ya es blanco sobre negro)\n",
        "    imagen_28 = imagen_28.astype(\"float32\") / 255.0\n",
        "    imagen_28 = imagen_28.reshape(1, 28, 28, 1)\n",
        "\n",
        "    pred = model.predict(imagen_28, verbose=0)\n",
        "    return {str(i): float(pred[0][i]) for i in range(10)}\n",
        "\n",
        "demo = gr.Interface(\n",
        "    fn=predecir,\n",
        "    inputs=gr.Sketchpad(\n",
        "        label=\"Dibujá un dígito aquí\",\n",
        "        type=\"numpy\",\n",
        "        brush=gr.Brush(\n",
        "            default_size=20,\n",
        "            colors=[\"#000000\"],\n",
        "            default_color=\"#000000\"\n",
        "        ),\n",
        "        canvas_size=(280, 280),\n",
        "    ),\n",
        "    outputs=gr.Label(\n",
        "        num_top_classes=10,\n",
        "        label=\"Probabilidades por dígito\"\n",
        "    ),\n",
        "    title=\"Clasificador de dígitos MNIST\",\n",
        "    live=False\n",
        ")\n",
        "\n",
        "demo.launch(inline=True, debug=True)"
      ]
    },
